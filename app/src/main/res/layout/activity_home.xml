<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#2E7D32"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="48sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasiru-Usiru"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textSize="16sp"
                android:textColor="#C8E6C9"/>

        </LinearLayout>

        <!-- Stats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Trees Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:gravity="center"
                android:layout_margin="4dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvHomeTreeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trees"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

            </LinearLayout>

            <!-- O2 Score Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:gravity="center"
                android:layout_margin="4dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvHomeO2Score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#66BB6A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="O2 Score"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

            </LinearLayout>

            <!-- Empty Pits Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:gravity="center"
                android:layout_margin="4dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvHomeEmptyPits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pits"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Menu Buttons - SQUARE GRID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Map Button -->
                <Button
                    android:id="@+id/btnHomeMap"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:text="🗺️\nMap"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_margin="4dp"/>

                <!-- Add Tree Button -->
                <Button
                    android:id="@+id/btnHomeAddTree"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:text="🌳\nAdd Tree"
                    android:backgroundTint="#388E3C"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_margin="4dp"/>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- O2 Score Button -->
                <Button
                    android:id="@+id/btnHomeOxygen"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:text="💨\nO2 Score"
                    android:backgroundTint="#43A047"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_margin="4dp"/>

                <!-- Species Button -->
                <Button
                    android:id="@+id/btnHomeSpecies"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:text="📖\nSpecies"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_margin="4dp"/>

            </LinearLayout>

            <!-- Logout Button - Full Width -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Logout"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_margin="4dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>